{
  "name": "@community/root",
  "private": true,
  "version": "0.1.0",
  "description": "Community workspace for pluggable packages and agents.",
  "packageManager": "pnpm@8.15.8",
  "scripts": {
    "create:package": "node ./scripts/create-package.mjs",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "check:entity-names": "node ./scripts/check-entity-names.mjs",
    "test": "pnpm run check:entity-names && pnpm -r run test",
    "release:publish": "pnpm -r --if-present run build && pnpm exec changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@langchain/openai": "0.6.9",
    "axios": "^1.12.2",
    "short-unique-id": "^5.3.2",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "overrides": {
      "@xpert-ai/plugin-sdk@3.11.2>@xpert-ai/contracts": "3.11.0",
      "@xpert-ai/plugin-sdk@3.12.0>@xpert-ai/contracts": "3.12.0",
      "@xpert-ai/plugin-sdk@3.12.1>@xpert-ai/contracts": "3.12.1",
      "@xpert-ai/plugin-sdk@3.15.0>@xpert-ai/contracts": "3.15.1",
      "@xpert-ai/plugin-sdk@3.15.4>@xpert-ai/contracts": "3.15.4"
    }
  }
}
