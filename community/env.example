# Copy this file to `community/.env` before installing community plugins into a local Xpert backend.
# Do not commit `community/.env`; it should contain local tokens and deployment-specific IDs.

# Xpert backend origin. The install endpoint is `${XPERT_API_URL}/api/plugin`.
XPERT_API_URL=http://localhost:3000/

# Bearer token for a user allowed to install plugins.
# For system/global plugins this must be a SUPER_ADMIN login JWT, preferably copied
# from the browser Authorization header. API keys or opaque bearer values are not
# enough for system plugin install guards. Store either the raw JWT or the header
# value `Bearer <jwt>`. Do not include the literal `Authorization:` prefix unless
# the deploy wrapper strips it before sending the request.
XPERT_TOKEN=

# Organization-scoped plugin installs require a real organization UUID.
# Leave empty when XPERT_INSTALL_SCOPE=global.
XPERT_ORG_ID=

# Optional tenant UUID. Usually not needed because the backend resolves it from the token.
XPERT_TENANT_ID=

# Use `organization` for normal organization plugins, `global` for system plugins.
XPERT_INSTALL_SCOPE=organization

# Default community plugin install target.
XPERT_PLUGIN_NAME=@xpert-ai/plugin-sales-ontology
XPERT_PLUGIN_WORKSPACE_PATH=./apps/sales-ontology

# Optional build overrides used by xpert-pro's `plugin:reinstall:local` helper.
XPERT_PLUGIN_BUILD_COMMAND=
XPERT_PLUGIN_BUILD_CWD=

# Optional JSON config payload passed to the plugin install API.
# Example for Sales Ontology:
XPERT_PLUGIN_CONFIG_JSON={"dataXpert":{"apiBaseUrl":"http://localhost:3000/","defaultResourceId":"sales-ontology"}}

# Optional Sites-specific config example. Do not reuse the Sales Ontology config
# above when installing @xpert-ai/plugin-sites.
# XPERT_SITES_PLUGIN_CONFIG_JSON={"defaultAccessMode":"workspace_all"}
