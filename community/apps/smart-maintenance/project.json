{
  "name": "smart-maintenance",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugins/smart-maintenance/src",
  "projectType": "library",
  "release": {
    "version": {
      "generatorOptions": {
        "packageRoot": "dist/{projectRoot}",
        "currentVersionResolver": "git-tag"
      }
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/plugins/smart-maintenance",
        "main": "packages/plugins/smart-maintenance/src/index.ts",
        "tsConfig": "packages/plugins/smart-maintenance/tsconfig.lib.json",
        "assets": [
          {
            "input": "packages/plugins/smart-maintenance/src/lib/remote-components",
            "glob": "**/*",
            "output": "remote-components"
          }
        ],
        "project": "packages/plugins/smart-maintenance/package.json",
        "compiler": "swc",
        "format": ["cjs", "esm"],
        "external": [
          "@langchain/core",
          "@nestjs/common",
          "@nestjs/core",
          "@nestjs/typeorm",
          "@nestjs/microservices",
          "@xpert-ai/contracts",
          "@xpert-ai/plugin-sdk",
          "typeorm",
          "react",
          "react-dom",
          "xlsx",
          "kafkajs",
          "amqplib",
          "mqtt",
          "nats",
          "zod"
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/plugins/smart-maintenance/jest.config.ts"
      }
    }
  }
}
