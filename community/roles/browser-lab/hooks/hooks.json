{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "xpertai_browser_*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/pre-tool-use.js"
          }
        ]
      }
    ]
  }
}
