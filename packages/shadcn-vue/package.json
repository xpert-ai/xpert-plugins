{
  "name": "@xpert-ai/plugin-shadcn-vue",
  "version": "0.1.0",
  "private": true,
  "description": "Shared shadcn-vue/Reka UI primitives for Xpert Vue remote component views.",
  "author": {
    "name": "XpertAI",
    "url": "https://xpertai.cn"
  },
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "components.json",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.lib.json --declaration --emitDeclarationOnly",
    "shadcn:add": "pnpm dlx shadcn-vue@latest add --cwd .",
    "test": "vue-tsc -p tsconfig.lib.json --noEmit",
    "typecheck": "vue-tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "@lucide/vue": "1.23.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "vue": ">=3.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^20.19.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.2.4",
    "vue": "^3.5.29",
    "vue-tsc": "^3.3.7"
  }
}
