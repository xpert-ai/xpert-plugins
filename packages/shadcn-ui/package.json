{
  "name": "@xpert-ai/plugin-shadcn-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Root shared shadcn/Radix React UI primitives for Xpert plugin remote component views.",
  "author": {
    "name": "XpertAI",
    "url": "https://xpertai.cn"
  },
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "imports": {
    "#components/*": {
      "shadcn-ui-source": "./src/components/*.tsx",
      "types": "./dist/components/*.d.ts",
      "default": "./src/components/*.tsx"
    },
    "#lib/*": {
      "shadcn-ui-source": "./src/lib/*.ts",
      "types": "./dist/lib/*.d.ts",
      "default": "./src/lib/*.ts"
    },
    "#hooks/*": {
      "shadcn-ui-source": "./src/hooks/*.ts",
      "types": "./dist/hooks/*.d.ts",
      "default": "./src/hooks/*.ts"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.lib.json --emitDeclarationOnly",
    "shadcn:preset-b0": "pnpm dlx shadcn@latest preset decode b0",
    "shadcn:add": "pnpm dlx shadcn@latest add --cwd .",
    "test": "tsc -p tsconfig.lib.json --noEmit",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "1.24.0",
    "react-resizable-panels": "^4.12.1",
    "radix-ui": "^1.6.2",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^20.19.9",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.8.3",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.0"
  }
}
