{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "preserveSymlinks": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "strict": true,
    "skipLibCheck": true,
    "importHelpers": true,
    "resolvePackageJsonImports": true,
    "customConditions": ["shadcn-ui-source"],
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}
