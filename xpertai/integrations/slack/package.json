  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@xpert-ai/contracts": "^3.10.0",
    "@xpert-ai/plugin-sdk": "^3.10.0",
