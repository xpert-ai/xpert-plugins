{
  "name": "@xpert-ai/plugin-slack",
  "version": "4.0.1",
  "description": "Slack integration plugin for XpertAI.",
  "author": {
    "name": "XpertAI",
    "url": "https://xpertai.cn"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpert-ai/xpert-plugins.git",
    "directory": "xpertai/integrations/slack"
  },
  "bugs": {
    "url": "https://github.com/xpert-ai/xpert-plugins/issues"
  },
  "homepage": "https://github.com/xpert-ai/xpert-plugins/tree/main/xpertai/integrations/slack#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
