INTEGRATION_LARK_HANDOFF_E2E_ENABLED=false
INTEGRATION_LARK_E2E_ENV_PATH=
INTEGRATION_LARK_E2E_BASE_URL=http://localhost:3000/api
INTEGRATION_LARK_E2E_TIMEOUT_MS=30000
INTEGRATION_LARK_E2E_MOCK_LARK_UPDATE=true

# Enable e2e ingress api on server side
INTEGRATION_LARK_E2E_API_ENABLED=false
INTEGRATION_LARK_E2E_API_KEY=

# Required request data for /lark/e2e/handoff/chat
INTEGRATION_LARK_E2E_TENANT_ID=e2e-tenant
INTEGRATION_LARK_E2E_ORGANIZATION_ID=e2e-org
INTEGRATION_LARK_E2E_USER_ID=e2e-user
INTEGRATION_LARK_E2E_INTEGRATION_ID=
INTEGRATION_LARK_E2E_CHAT_ID=
INTEGRATION_LARK_E2E_SENDER_OPEN_ID=
INTEGRATION_LARK_E2E_XPERT_ID=
INTEGRATION_LARK_E2E_INPUT=Hello from integration-lark e2e
INTEGRATION_LARK_E2E_LANGUAGE=en_US
INTEGRATION_LARK_E2E_LARK_MESSAGE_ID=

# Enable real Lark SDK API e2e on this package
INTEGRATION_LARK_CLIENT_E2E_ENABLED=false
INTEGRATION_LARK_CLIENT_E2E_ENV_PATH=
INTEGRATION_LARK_CLIENT_E2E_TIMEOUT_MS=30000

# Required client credentials (fallback: LARK_APP_ID / LARK_APP_SECRET)
INTEGRATION_LARK_CLIENT_APP_ID=
INTEGRATION_LARK_CLIENT_APP_SECRET=
INTEGRATION_LARK_CLIENT_IS_LARK=false

# Per-api switches
INTEGRATION_LARK_CLIENT_E2E_ENABLE_DEPARTMENT_CHILDREN=true
INTEGRATION_LARK_CLIENT_E2E_ENABLE_USER_FIND_BY_DEPARTMENT=true
INTEGRATION_LARK_CLIENT_E2E_ENABLE_CHAT_LIST=true

# contact.v3.department.children inputs
INTEGRATION_LARK_CLIENT_DEPARTMENT_ID=0
INTEGRATION_LARK_CLIENT_DEPARTMENT_ID_TYPE=open_department_id
INTEGRATION_LARK_CLIENT_FETCH_CHILD=true
INTEGRATION_LARK_CLIENT_DEPARTMENT_PAGE_SIZE=50

# contact.v3.user.findByDepartment inputs
INTEGRATION_LARK_CLIENT_USER_DEPARTMENT_ID=
INTEGRATION_LARK_CLIENT_USER_ID_TYPE=open_id
INTEGRATION_LARK_CLIENT_USER_PAGE_SIZE=50

# im.chat.list inputs
INTEGRATION_LARK_CLIENT_CHAT_LIST_WITH_PARAMS=false
INTEGRATION_LARK_CLIENT_CHAT_PAGE_SIZE=20
