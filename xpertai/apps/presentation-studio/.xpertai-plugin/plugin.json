{
  "name": "@xpert-ai/plugin-presentation-studio",
  "version": "0.6.6",
  "description": "Agentic DashiAI presentation studio with custom theme generation, Yjs collaboration, and HTML/PDF/PPTX export.",
  "author": "XpertAI",
  "homepage": "https://github.com/xpert-ai/xpert-plugins/tree/main/xpertai/apps/presentation-studio",
  "repository": "https://github.com/xpert-ai/xpert-plugins/tree/main/xpertai/apps/presentation-studio",
  "license": "AGPL-3.0",
  "keywords": ["presentation", "pptx", "pdf", "dashi", "yjs", "collaboration", "agentic-app"],
  "skills": "./skills/",
  "sandboxActions": "./dist/sandbox-actions/presentation-export/action.json",
  "interface": {
    "displayName": "Presentation Studio",
    "shortDescription": "Agent-ready presentation studio",
    "longDescription": "Generate, edit, collaborate on, version, and export presentations with 14 built-in DashiAI themes, 1190 layouts, and verified themes generated from uploaded templates.",
    "developerName": "XpertAI",
    "category": "Productivity",
    "capabilities": ["Interactive", "Read", "Write"],
    "websiteURL": "https://xpertai.cn",
    "privacyPolicyURL": "https://xpertai.cn",
    "termsOfServiceURL": "https://xpertai.cn",
    "defaultPrompt": ["Create a project presentation", "Generate a theme from my template", "Generate an editable PPTX", "Review and export the current deck"],
    "composerIcon": "./assets/composerIcon.svg",
    "logo": "./assets/logo.svg",
    "brandColor": "#7C3AED",
    "screenshots": []
  },
  "policy": { "installation": "AVAILABLE", "authentication": "ON_FIRST_USE", "pluginSharing": true },
  "source": {
    "source": "local",
    "path": ".",
    "url": "https://github.com/xpert-ai/xpert-plugins",
    "sparsePath": "xpertai/apps/presentation-studio"
  },
  "assets": { "composerIcon": "./assets/composerIcon.svg", "logo": "./assets/logo.svg", "screenshots": [] },
  "targetApps": ["data-xpert", "xpert"],
  "targetAppMeta": {
    "xpert": {
      "types": ["assistant-template", "skill", "app", "xpertai-bundle"],
      "capabilities": ["presentation-studio", "presentation-generation", "presentation-theme-generation", "presentation-workbench", "presentation-collaboration", "presentation-export", "presentation-assistant-template"]
    },
    "data-xpert": {
      "types": ["workbench-view", "assistant-tool", "business-app"],
      "capabilities": ["presentation-studio", "presentation-generation", "presentation-theme-generation", "presentation-workbench", "presentation-collaboration", "presentation-export", "presentation-assistant-template"]
    }
  }
}
