{
  "name": "dashi-ppt-runtime",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "themes:generate": "node scripts/generate-theme-family.mjs && tsx scripts/update-generated-theme-metadata.jsx",
    "themes:build-generated": "node scripts/build-generated-theme-runtimes.mjs",
    "themes:validate-generated": "node scripts/validate-generated-theme-capabilities.mjs",
    "themes:validate-palette": "tsx scripts/validate-generated-theme-palette.jsx",
    "themes:render-audit": "tsx scripts/render-generated-theme-audit.jsx",
    "themes:render-owned": "tsx scripts/render-theme-owned-audit.jsx",
    "themes:style-grid": "node scripts/generate-theme-style-grid.mjs",
    "themes:sync-skill": "node scripts/sync-generated-theme-skill-entry.mjs",
    "themes:finalize": "node ../scripts/finalize-plugin-theme.mjs --project .",
    "themes:validate-layout": "node ../scripts/validate-generated-layout-quality.mjs --project .",
    "themes:analyze-baselines": "node scripts/analyze-theme-baselines.mjs",
    "themes:new": "node scripts/prepare-new-theme.mjs",
    "themes:external-plan": "node scripts/prepare-external-theme.mjs",
    "themes:extract-source": "node ../scripts/extract-theme-source.mjs --project .",
    "themes:scaffold-owned": "node scripts/scaffold-theme-owned-modules.mjs",
    "themes:test-derived-provenance": "node ../tests/validate-derived-provenance.mjs",
    "themes:package-plugin": "node scripts/package-presentation-theme.mjs",
    "manifest:update": "tsx scripts/update-layout-manifest.jsx",
    "layout:query": "node scripts/layout-query.mjs",
    "inspect:layout": "node scripts/inspect-layout.mjs",
    "media:stage": "node scripts/stage-media.mjs",
    "props:safe": "node scripts/write-safe-props.mjs",
    "goal:scaffold": "node scripts/goal-scaffold.mjs",
    "validate:goal-spec": "node scripts/validate-goal-spec.mjs",
    "render:goal": "tsx scripts/render-goal-deck.jsx",
    "preview:https": "node scripts/serve-preview-https.mjs",
    "preview:start": "node scripts/start-preview-server.mjs",
    "validate:swiss": "node scripts/validate-swiss-deck.mjs",
    "validate:goal-copy": "node scripts/validate-goal-copy.mjs",
    "export:pptx": "node scripts/export-pptx.mjs",
    "export:pdf": "node scripts/export-pptx.mjs --pdf"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "jszip": "3.10.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "tsx": "^4.20.0",
    "esbuild": "^0.28.0",
    "pngjs": "^7.0.0",
    "playwright-core": "^1.60.0",
    "pdf-lib": "^1.17.1"
  }
}
