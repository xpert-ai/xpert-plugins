  "localChanges": [
    "project/src/renderDeck.jsx resolves runtime dependencies from the containing plugin package",
    "presentation fonts are supplied by exact-version Fontsource dependencies and staged per selected theme instead of being committed as vendor binaries",
    "project/assets/template-swiss.html loads the generated theme-aware font pack and its license inventory",
    "project/scripts/export-pptx.mjs can emit a machine-readable export warning report",
    "project/packages/html-deck-to-pptx/src/screenshot.mjs captures prepared slides with a page clip so Playwright does not repeat element-stability waits",
    "project/scripts/serve-preview-https.mjs accepts DASHI_PPT_CERT_DIR so export jobs keep certificates inside their temporary directory",
    "volatile project/output/https-preview development certificates are excluded from the vendored tree",
    "theme13 and theme14 add only their owned page closures plus one shared generated-theme composition layer; reused theme02/03/04/05/09/12 source modules remain single-copy",
    "generated themes ship as two ESM entries plus one shared content-hash chunk; no per-generated-theme standalone IIFE is vendored"
  ],
