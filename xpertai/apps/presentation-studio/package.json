{
  "name": "@xpert-ai/plugin-presentation-studio",
  "version": "0.4.0",
  "description": "Agentic presentation studio with the DashiAI layout catalog, Yjs collaboration, and HTML/PDF/PPTX export.",
  "author": {
    "name": "XpertAI",
    "url": "https://xpertai.cn"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpert-ai/xpert-plugins.git",
    "directory": "xpertai/apps/presentation-studio"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@xpert-plugins-starter/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "scripts",
    ".xpertai-plugin",
    "assets",
    "skills",
    "README.md",
    "README_zh-hans.md",
    "THIRD_PARTY_NOTICES.md",
    "!assets/upstream/dashiai-ppt/project/**",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build:ui": "pnpm --filter @xpert-ai/plugin-shadcn-ui build",
    "sync:theme-runtime": "node scripts/sync-theme-runtime.mjs",
    "verify:vendor": "pnpm run sync:theme-runtime && node scripts/verify-vendor.mjs",
    "build:sandbox-action": "node scripts/build-sandbox-action.mjs",
    "verify:sandbox-action": "node scripts/verify-sandbox-action.mjs",
    "verify:vendor:deep": "pnpm run sync:theme-runtime && node scripts/verify-vendor.mjs --deep",
    "build": "pnpm run build:ui && node scripts/clean-dist.mjs && node scripts/build-remote-components.mjs && tsc -p tsconfig.lib.json && node scripts/copy-assets.mjs && pnpm run verify:vendor && pnpm run build:sandbox-action && pnpm run verify:sandbox-action && node scripts/verify-package-output.mjs",
    "lint": "echo \"(todo) add lint\"",
    "test": "pnpm run build:ui && TS_NODE_PROJECT=tsconfig.jest.json jest --config jest.config.ts --runInBand && tsc -p tsconfig.spec.json --noEmit && node scripts/build-remote-components.mjs --check && pnpm run verify:vendor && pnpm run build:sandbox-action && pnpm run verify:sandbox-action",
    "typecheck": "pnpm run build:ui && tsc -p tsconfig.spec.json --noEmit && tsc -p tsconfig.remote.json --noEmit && node scripts/build-remote-components.mjs --check",
    "test:catalog": "pnpm run verify:vendor:deep && tsx scripts/validate-catalog-render.jsx",
    "test:catalog:browser": "pnpm run verify:vendor:deep && tsx scripts/validate-catalog-render.jsx --browser",
    "test:export-matrix": "pnpm run verify:vendor:deep && tsx scripts/validate-export-matrix.jsx && node scripts/verify-vendor.mjs --deep",
    "prepack": "pnpm run build:ui && npm run build"
  },
  "xpert": {
    "plugin": {
      "level": "system"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/anton": "5.2.7",
    "@fontsource/archivo": "5.2.8",
    "@fontsource/caveat": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/ibm-plex-sans": "5.2.8",
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/newsreader": "5.2.10",
    "@fontsource/space-grotesk": "5.2.10",
    "@fontsource/space-mono": "5.2.9",
    "esbuild": "^0.27.0",
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "pdf-lib": "^1.17.1",
    "jszip": "3.10.1",
    "playwright-core": "1.61.0",
    "pngjs": "^7.0.0",
    "pptxgenjs": "^4.0.1",
    "socket.io-client": "^4.8.1",
    "tslib": "^2.3.0",
    "tsx": "^4.20.6",
    "yjs": "13.6.31"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/typeorm": "^11.0.0",
    "@xpert-ai/contracts": "^3.15.12",
    "@xpert-ai/plugin-sdk": "^3.15.12",
    "rxjs": ">=7.0.0",
    "typeorm": "^0.3.24",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@langchain/core": "0.3.72",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/typeorm": "^11.0.0",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@swc/jest": "~0.2.38",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@xpert-ai/contracts": "3.15.12",
    "@xpert-ai/plugin-shadcn-ui": "workspace:*",
    "@xpert-ai/plugin-sdk": "3.15.12",
    "jest": "^29.7.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.24",
    "typescript": "^5.9.2",
    "zod": "3.25.67"
  },
  "publishConfig": {
    "access": "public"
  }
}
