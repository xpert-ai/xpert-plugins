  "interface": {
    "displayName": "Excalidraw",
    "shortDescription": "Collaborative Agent-managed Excalidraw diagrams",
    "longDescription": "Create, co-edit, version, review, import, export, and share Agent-generated Excalidraw diagrams. Live collaboration uses platform-owned Yjs documents and presence. Sharing publishes a safe self-contained read-only Excalidraw HTML viewer through platform Artifacts with controlled access and revocation. The optional technical diagram engine adds templates, DiagramIR, deterministic rendering, and quality review.",
    "developerName": "XpertAI",
    "category": "Productivity",
    "capabilities": [
      "Interactive",
      "Read",
      "Write"
    ],
    "websiteURL": "https://xpertai.cn",
    "privacyPolicyURL": "https://xpertai.cn",
    "termsOfServiceURL": "https://xpertai.cn",
    "defaultPrompt": [
      "Create an editable architecture diagram",
      "Turn this flow into an Excalidraw drawing",
      "Update the current Excalidraw canvas from my feedback",
      "Create and visually review a RAG architecture from a built-in template"
    ],
    "composerIcon": "./assets/composerIcon.svg",
    "logo": "./assets/logo.svg",
    "brandColor": "#6965DB",
    "screenshots": []
  },
  "policy": {
    "installation": "AVAILABLE",
    "authentication": "ON_FIRST_USE",
    "pluginSharing": true
  },
  "source": {
    "source": "local",
    "path": ".",
    "url": "https://github.com/xpert-ai/xpert-plugins",
    "sparsePath": "xpertai/apps/excalidraw"
  },
