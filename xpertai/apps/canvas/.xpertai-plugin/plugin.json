{
  "name": "@xpert-ai/plugin-canvas",
  "version": "0.1.0",
  "description": "Canvas app plugin for agent-managed tldraw infinite canvases, image holders, annotation workflows, reviewable versions, and an editable workbench.",
  "author": "XpertAI",
  "homepage": "https://github.com/xpert-ai/xpert-plugins/tree/main/xpertai/apps/canvas",
  "repository": "https://github.com/xpert-ai/xpert-plugins/tree/main/xpertai/apps/canvas",
  "license": "AGPL-3.0",
  "keywords": [
    "canvas",
    "tldraw",
    "whiteboard",
    "image-generation",
    "annotation",
    "agent-canvas",
    "workbench"
  ],
  "skills": "./skills/",
  "interface": {
    "displayName": "Canvas",
    "shortDescription": "Agent-managed tldraw canvases",
    "longDescription": "Create, update, version, review, annotate, insert images, import, and export Agent-managed tldraw infinite canvases. The plugin includes an installable Xpert skill, Assistant template, middleware tools, and a Canvas Workbench for human review.",
    "developerName": "XpertAI",
    "category": "Productivity",
    "capabilities": [
      "Interactive",
      "Read",
      "Write"
    ],
    "websiteURL": "https://xpertai.cn",
    "privacyPolicyURL": "https://xpertai.cn",
    "termsOfServiceURL": "https://xpertai.cn",
    "defaultPrompt": [
      "Open a new visual canvas for planning this project.",
      "Create AI image slots on a canvas for these product concepts.",
      "Insert this generated image into the selected Canvas image holder."
    ],
    "composerIcon": "./assets/composerIcon.svg",
    "logo": "./assets/logo.svg",
    "brandColor": "#0F766E",
    "screenshots": []
  },
  "policy": {
    "installation": "AVAILABLE",
    "authentication": "ON_FIRST_USE",
    "pluginSharing": true
  },
  "source": {
    "source": "local",
    "path": ".",
    "url": "https://github.com/xpert-ai/xpert-plugins",
    "sparsePath": "xpertai/apps/canvas"
  },
  "assets": {
    "composerIcon": "./assets/composerIcon.svg",
    "logo": "./assets/logo.svg",
    "screenshots": []
  },
  "targetApps": [
    "data-xpert",
    "xpert"
  ],
  "targetAppMeta": {
    "xpert": {
      "types": [
        "assistant-template",
        "skill",
        "app",
        "xpertai-bundle"
      ],
      "capabilities": [
        "canvas",
        "canvas-workbench",
        "agent-canvas",
        "canvas-assistant-template"
      ],
      "marketplace": {
        "contents": [
          {
            "type": "skill",
            "name": "canvas-agent-skill",
            "displayName": "Canvas Agent Skill",
            "description": "Skill for using Canvas middleware tools, Workbench selection context, tldraw snapshot inspection, record patching, image insertion, versioning, and recovery.",
            "tags": [
              "skill",
              "canvas",
              "tldraw",
              "agent-canvas",
              "middleware-tools"
            ]
          },
          {
            "type": "assistant-template",
            "name": "canvas-assistant",
            "displayName": "Canvas Assistant",
            "description": "Assistant template for Canvas visual workflows."
          },
          {
            "type": "app",
            "name": "canvas",
            "displayName": "Canvas",
            "description": "Workbench and Agent middleware tools for tldraw canvases."
          }
        ]
      }
    },
    "data-xpert": {
      "types": [
        "workbench-view",
        "assistant-tool",
        "business-app"
      ],
      "capabilities": [
        "canvas",
        "canvas-workbench",
        "agent-canvas",
        "canvas-assistant-template"
      ]
    }
  }
}
