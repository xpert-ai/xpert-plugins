{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "React.Fragment",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "strictNullChecks": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@xpert-ai/plugin-shadcn-ui": ["../../../packages/shadcn-ui/src/index.ts"],
      "@/*": ["../../../packages/shadcn-ui/src/*"]
    }
  },
  "include": [
    "src/lib/remote-components/canvas-workbench/src/**/*.ts",
    "src/lib/remote-components/canvas-workbench/src/**/*.tsx"
  ],
  "exclude": ["dist", "node_modules"]
}
