{
  "name": "@xpert-ai/plugin-cut",
  "version": "0.1.0",
  "description": "Agentic non-linear video editor for Xpert, adapted from the pinned OpenCut pre-rewrite editor architecture.",
  "author": {
    "name": "XpertAI",
    "url": "https://xpertai.cn"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpert-ai/xpert-plugins.git",
    "directory": "xpertai/apps/cut"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "xpert-cut-ir-mcp": "./dist/mcp-server.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@xpert-plugins-starter/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./mcp-server": {
      "@xpert-plugins-starter/source": "./src/mcp-server.ts",
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js",
      "default": "./dist/mcp-server.js"
    }
  },
  "files": [
    "dist",
    ".xpertai-plugin",
    "assets",
    "docs",
    "skills",
    "README*.md",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build:ui": "pnpm --filter @xpert-ai/plugin-shadcn-ui build",
    "build:sandbox-action": "node scripts/build-sandbox-action.mjs",
    "verify:sandbox-action": "node scripts/verify-sandbox-action.mjs",
    "smoke:mcp-server": "node scripts/smoke-mcp-server.mjs",
    "smoke:sandbox-action": "pnpm run build:sandbox-action && pnpm run verify:sandbox-action && node scripts/smoke-sandbox-action.mjs",
    "build": "pnpm run build:ui && node scripts/build-remote-components.mjs && tsc -p tsconfig.lib.json && node scripts/copy-assets.mjs && pnpm run build:sandbox-action && pnpm run verify:sandbox-action",
    "lint": "echo \"(todo) add lint\"",
    "test": "pnpm run build:ui && jest --config jest.config.ts && tsc -p tsconfig.spec.json --noEmit && tsc -p tsconfig.remote.json --noEmit && node scripts/build-remote-components.mjs --check && pnpm run build:sandbox-action && pnpm run verify:sandbox-action",
    "test:e2e": "node scripts/verify-workbench-e2e.mjs",
    "typecheck": "pnpm run build:ui && tsc -p tsconfig.spec.json --noEmit && tsc -p tsconfig.remote.json --noEmit && node scripts/build-remote-components.mjs --check",
    "prepack": "npm run build && node scripts/verify-package-output.mjs && npm run smoke:mcp-server"
  },
  "xpert": {
    "plugin": {
      "level": "system"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mediabunny": "1.29.1",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/typeorm": "^11.0.0",
    "@xpert-ai/contracts": "^3.10.1",
    "@xpert-ai/plugin-sdk": "^3.15.7",
    "react": ">=18",
    "react-dom": ">=18",
    "typeorm": "^0.3.24",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@huggingface/transformers": "4.2.0",
    "@langchain/core": "0.3.72",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/typeorm": "^11.0.0",
    "@swc/jest": "~0.2.38",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.9",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@xpert-ai/contracts": "3.10.1",
    "@xpert-ai/plugin-shadcn-ui": "workspace:*",
    "@xpert-ai/plugin-sdk": "^3.15.7",
    "esbuild": "^0.27.0",
    "jest": "^30.0.2",
    "lucide-react": "1.24.0",
    "playwright": "1.61.0",
    "playwright-core": "1.61.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.24",
    "typescript": "^5.9.2",
    "zod": "3.25.67"
  },
  "publishConfig": {
    "access": "public"
  }
}
