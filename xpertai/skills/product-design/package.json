{
  "name": "@xpert-ai/plugin-product-design",
  "version": "0.1.1",
  "description": "Xpert skill-only plugin for Product Design workflows converted from the Codex Product Design skill plugin.",
  "author": {
    "name": "XpertAI",
    "url": "https://xpertai.cn"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpert-ai/xpert-plugins.git",
    "directory": "xpertai/skills/product-design"
  },
  "bugs": {
    "url": "https://github.com/xpert-ai/xpert-plugins/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@xpert-plugins-starter/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    ".xpertai-plugin",
    "assets",
    "skills",
    "references",
    "scripts",
    "templates",
    "README.md",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "lint": "echo \"(todo) add lint\"",
    "test": "tsc -p tsconfig.lib.json --noEmit",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "prototype:bootstrap": "node scripts/bootstrap-prototype.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@xpert-ai/contracts": "^3.10.1",
    "@xpert-ai/plugin-sdk": "^3.10.1"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@types/node": "^20.19.9",
    "@xpert-ai/contracts": "3.10.1",
    "@xpert-ai/plugin-sdk": "3.10.1",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
